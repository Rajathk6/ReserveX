model RefreshToken {
    id String @id @default(cuid())
    token String @unique
    expiresAt DateTime @db.Timestamptz(3)
    createdAt DateTime @default(now()) @db.Timestamptz(3)
    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("refresh_tokens")
}