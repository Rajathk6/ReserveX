model User {
    id           String   @id @default(cuid())
    email        String   @unique
    fullName     String
    passwordHash String
    isActive     Boolean  @default(true)
    role         UserRole @default(USER)

    createdAt DateTime @default(now()) @db.Timestamptz(3)
    updatedAt DateTime @updatedAt @db.Timestamptz(3)

    refreshTokens RefreshToken[]
    events        Event[]

    @@map("users")
}
